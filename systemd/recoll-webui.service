[Unit]
Description=Recoll WebUI
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/recollwebui
ExecStart=/usr/bin/python3 /home/ubuntu/recollwebui/webui-standalone.py --addr 0.0.0.0 --port 8080 -c /home/ubuntu/.config/Recoll
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
